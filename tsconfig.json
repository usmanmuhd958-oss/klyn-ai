{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@orchestrator/*": ["packages/ai-orchestrator/src/*"],
      "@gateway/*": ["packages/ai-gateway/src/*"],
      "@runtime/*": ["packages/agent-runtime/src/*"],
      "@workflow/*": ["packages/workflow-engine/src/*"]
    },
    "strict": false,
    "esModuleInterop": true
  }
}
